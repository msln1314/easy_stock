# 环境变量配置示例文件
# 复制此文件为 .env 并填入实际的配置值

# Redis 缓存配置
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=akshare:
REDIS_TIMEOUT=3
REDIS_CACHE_EXPIRATION=3600

# Tushare Pro 配置
# 获取 token: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# GM（掘金量化）配置
# GM SDK 通常不需要 token，但预留配置项
# 如需认证，请联系掘金量化官方
GM_TOKEN=

# AKShare 配置
AKSHARE_TIMEOUT=60.0

# 日志配置
LOG_LEVEL=INFO
